# ===== ModelHub 环境变量 =====
# 复制为 .env 并填入实际值
# 不要提交 .env 到 git！

# --- MySQL ---
MYSQL_ROOT_PASSWORD=CHANGE_ME_随机32位

# --- Redis ---
REDIS_PASSWORD=CHANGE_ME_随机32位

# --- NewAPI ---
SESSION_SECRET=CHANGE_ME_随机64位
# 初始管理员 token（首次启动时设置，之后可删）
INITIAL_ROOT_TOKEN=

# --- 域名（部署脚本和 Nginx 使用） ---
DOMAIN=api.modelhub.cn

# --- COS 备份（可选） ---
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=
COS_REGION=ap-shanghai

# --- 飞书告警（可选） ---
FEISHU_WEBHOOK_URL=
